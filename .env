# =============================================================================
# SCIE — Social Intelligence Engine
# Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=SCIE
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
APP_FRONTEND_URL=http://localhost:3000
APP_API_URL=http://localhost:8000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-very-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=scie
POSTGRES_USER=scie
POSTGRES_PASSWORD=scie_secret_password
DATABASE_URL=postgresql+asyncpg://scie:scie_secret_password@localhost:5433/scie

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# TikTok Research API Credentials
TIKTOK_APP_ID=7665669886001235989
TIKTOK_ORG_ID=7665678484718552085
TIKTOK_CLIENT_SECRET=

# Redis Streams
REDIS_STREAM_RAW_POSTS=stream:raw_posts
REDIS_STREAM_ENRICHED_POSTS=stream:enriched_posts
REDIS_STREAM_GRAPH_EVENTS=stream:graph_events
REDIS_STREAM_MAX_LEN=100000      # max messages per stream before trimming


# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scie_neo4j_password
NEO4J_DATABASE=scie

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=scie_minio_access
MINIO_SECRET_KEY=scie_minio_secret_key
MINIO_BUCKET_RAW=scie-raw-data
MINIO_BUCKET_REPORTS=scie-reports
MINIO_BUCKET_MODELS=scie-models
MINIO_SECURE=false

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_POSTS=scie_posts
ELASTICSEARCH_INDEX_ENTITIES=scie_entities

# ─── Qdrant (Vector Store) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_POSTS=scie_posts_embeddings

# ─── Ollama (Self-hosted Llama) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b              # llama3.1:8b | llama3.1:70b | llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── HuggingFace ──────────────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_your_token_here    # Optional, for private models
HF_MODEL_SENTIMENT=mdhuggins/indobert-sentiment
HF_MODEL_NER=cahya/bert-base-indonesian-NER
HF_MODEL_EMBEDDING=paraphrase-multilingual-MiniLM-L12-v2
HF_MODEL_TOPIC=facebook/bart-large-mnli
HF_MODEL_LANG_DETECT=lid.176.bin

# ─── Data Sources ─────────────────────────────────────────────────────────────
# Twitter/X API
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# ─── NLP Worker ───────────────────────────────────────────────────────────────
NLP_WORKER_CONCURRENCY=4
NLP_BATCH_SIZE=32
NLP_MAX_TEXT_LENGTH=1000     # chars, truncate beyond this

# ─── Graph Service ────────────────────────────────────────────────────────────
GRAPH_BATCH_SIZE=100
GRAPH_ANALYTICS_INTERVAL=3600    # seconds, default: 1 hour
GRAPH_COMMUNITY_DETECTION_INTERVAL=86400  # seconds, default: 24 hours

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
